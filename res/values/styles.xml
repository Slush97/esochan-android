        <item name="editTextPreferenceStyle">@style/EsoEditTextPreference</item>
        <item name="dropdownPreferenceStyle">@style/EsoDropDownPreference</item>
    </style>

    <style name="EsoPreference" parent="@style/Preference.Material">
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="EsoPreferenceCategory" parent="@style/Preference.Category.Material">
        <item name="iconSpaceReserved">false</item>
