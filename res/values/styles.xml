    <style name="SelectableItem">
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>

    <style name="Widget_Eso_IconButton">
        <item name="android:layout_width">@dimen/panel_icon_button</item>
        <item name="android:layout_height">@dimen/panel_icon_button</item>
        <item name="android:minWidth">@dimen/panel_icon_button</item>
        <item name="android:minHeight">@dimen/panel_icon_button</item>
        <item name="android:padding">@dimen/panel_icon_padding</item>
        <item name="android:background">?android:attr/selectableItemBackgroundBorderless</item>
        <item name="android:scaleType">center</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>
    
    <style name="Transparent">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.8</item>
    </style>

    <!-- Material Preference reserves empty icon gutters on sw360dp+; old PreferenceActivity did not.
         Category headers use itemInfoForeground (muted chrome), not postNameForeground (4chan name green/blue). -->
    <style name="EsoPreferenceTheme" parent="@style/PreferenceThemeOverlay">
        <item name="preferenceCategoryTitleTextColor">?attr/itemInfoForeground</item>
        <item name="preferenceStyle">@style/EsoPreference</item>
        <item name="preferenceCategoryStyle">@style/EsoPreferenceCategory</item>
        <item name="preferenceScreenStyle">@style/EsoPreference</item>
        <item name="checkBoxPreferenceStyle">@style/EsoCheckBoxPreference</item>
        <item name="dialogPreferenceStyle">@style/EsoDialogPreference</item>
        <item name="editTextPreferenceStyle">@style/EsoEditTextPreference</item>
        <item name="dropdownPreferenceStyle">@style/EsoDropDownPreference</item>
        <item name="preferenceFragmentCompatStyle">@style/EsoPreferenceFragment</item>
    </style>

    <style name="EsoPreferenceFragment" parent="@style/PreferenceFragment.Material">
        <item name="android:divider">@drawable/preference_divider</item>
        <item name="allowDividerAfterLastItem">false</item>
    </style>

    <!-- Material defaults allowDividerAbove=false, so hairlines never draw between rows. -->
    <style name="EsoPreference" parent="@style/Preference.Material">
        <item name="iconSpaceReserved">false</item>
        <item name="allowDividerAbove">true</item>
        <item name="allowDividerBelow">true</item>
    </style>

    <style name="EsoPreferenceCategory" parent="@style/Preference.Category.Material">
        <item name="iconSpaceReserved">false</item>
        <item name="allowDividerAbove">true</item>
        <item name="allowDividerBelow">true</item>
    </style>

    <style name="EsoCheckBoxPreference" parent="@style/Preference.CheckBoxPreference.Material">
        <item name="iconSpaceReserved">false</item>
        <item name="allowDividerAbove">true</item>
        <item name="allowDividerBelow">true</item>
    </style>

    <style name="EsoDialogPreference" parent="@style/Preference.DialogPreference.Material">
        <item name="iconSpaceReserved">false</item>
        <item name="allowDividerAbove">true</item>
        <item name="allowDividerBelow">true</item>
    </style>

    <style name="EsoEditTextPreference" parent="@style/Preference.DialogPreference.EditTextPreference.Material">
        <item name="iconSpaceReserved">false</item>
        <item name="allowDividerAbove">true</item>
        <item name="allowDividerBelow">true</item>
    </style>

    <style name="EsoDropDownPreference" parent="@style/Preference.DropDown.Material">
        <item name="iconSpaceReserved">false</item>
        <item name="allowDividerAbove">true</item>
        <item name="allowDividerBelow">true</item>
    </style>

